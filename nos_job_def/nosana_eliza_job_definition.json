{
  "ops": [
    {
      "id": "agent",
      "args": {
        "image": "yourusername/healthimus-agent:latest",
        "expose": 3000,
        "env": {
          "OPENAI_API_KEY": "nosana",
          "OPENAI_API_URL": "TODO: replace with actual Nosana Qwen3.5 endpoint URL",
          "MODEL_NAME": "Qwen3.5-27B-AWQ-4bit",
          "SERVER_PORT": "3000",
          "NODE_ENV": "production",
          "HEALTHIMUS_APP_NAME": "Healthimus",
          "HEALTHIMUS_TIMEZONE": "UTC"
        }
      },
      "execution": {
        "group": "run"
      },
      "type": "container/run"
    }
  ],
  "version": "0.1"
}
