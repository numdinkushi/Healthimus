# Eliza agent HTTP API (run `bun run dev` in repo root — default port 3000).
# Run Next on another port to avoid clashing, e.g. `PORT=3001 npm run dev`
HEALTHIMUS_AGENT_BASE_URL=http://localhost:3000

# Optional: pin agent UUID from GET /api/agents when multiple agents exist
# HEALTHIMUS_AGENT_ID=

# Anonymous user id (UUID) until Google OAuth is wired
HEALTHIMUS_ANONYMOUS_USER_ID=00000000-0000-4000-8000-000000000001

# Convex — client (dashboard “Cloud URL”, ends with .convex.cloud)
NEXT_PUBLIC_CONVEX_URL=

# Convex — HTTP Actions (dashboard “HTTP Actions URL”, ends with .convex.site); optional until you use httpAction routes
CONVEX_HTTP_ACTIONS_URL=

# Shared secret used by Next.js -> Convex HTTP Action sync endpoint
# Set same value in Convex env: HEALTHIMUS_CONVEX_SYNC_SECRET
HEALTHIMUS_CONVEX_SYNC_SECRET=

# Google OAuth (Auth.js)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Auth.js secret (`openssl rand -base64 32`)
AUTH_SECRET=
